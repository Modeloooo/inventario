@model Inventario.Models.ViewModels.EditViewModel

@{
    ViewBag.Title = "Editar producto";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<div class="page-header">
    <div>
        <h1>Editar producto</h1>
        <p class="subtitle">#@Model.Id — @Model.Nombre</p>
    </div>
    <a href="@Url.Action("Index")" class="btn btn-ghost">Cancelar</a>
</div>

@if (ViewBag.ValorMensaje != null)
{
    if (ViewBag.ValorMensaje == 1)
    {
        <div class="alert alert-success">
            <span class="alert-icon">&#10003;</span>
            @ViewBag.MensajeProceso
        </div>
    }
    else
    {
        <div class="alert alert-error">
            <span class="alert-icon">&#9888;</span>
            @ViewBag.MensajeProceso
        </div>
    }
}

<div class="card" style="padding:2rem;max-width:680px;">
    @using (Html.BeginForm("Edit", "Producto", FormMethod.Post))
    {
        @Html.AntiForgeryToken()
        @Html.HiddenFor(m => m.Id)

        <div class="form-grid">
            <div class="form-group full">
                @Html.LabelFor(m => m.Nombre, "Nombre del producto")
                @Html.TextBoxFor(m => m.Nombre, new { @class = "form-control" })
                @Html.ValidationMessageFor(m => m.Nombre)
            </div>

            <div class="form-group">
                @Html.LabelFor(m => m.Precio, "Precio ($)")
                @Html.TextBoxFor(m => m.Precio, new { @class = "form-control", type = "number", step = "0.01", min = "0" })
                @Html.ValidationMessageFor(m => m.Precio)
            </div>

            <div class="form-group">
                @Html.LabelFor(m => m.Stock, "Stock")
                @Html.TextBoxFor(m => m.Stock, new { @class = "form-control", type = "number", min = "0" })
                @Html.ValidationMessageFor(m => m.Stock)
            </div>

            <div class="form-group full">
                @Html.LabelFor(m => m.Descripcion, "Descripción")
                @Html.TextAreaFor(m => m.Descripcion, new { @class = "form-control" })
                @Html.ValidationMessageFor(m => m.Descripcion)
            </div>
        </div>

        <div style="margin-top:1.75rem;display:flex;gap:.5rem;align-items:center;">
            <button type="submit" class="btn btn-primary">Guardar cambios</button>
            <a href="@Url.Action("Details", new { id = Model.Id })" class="btn btn-ghost">Ver detalle</a>
            <a href="@Url.Action("Index")" class="btn btn-ghost">Cancelar</a>
        </div>
    }
</div>

@section Scripts {
    @Scripts.Render("~/bundles/jqueryval")
}
