@model Inventario.Models.Producto

@{
    ViewBag.Title = "Detalle del producto";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<div class="page-header">
    <div>
        <h1>@Model.Nombre</h1>
        <p class="subtitle">ID #@Model.Id</p>
    </div>
    <div style="display:flex;gap:.5rem;">
        <a href="@Url.Action("Edit", new { id = Model.Id })" class="btn btn-secondary">Editar</a>
        <a href="@Url.Action("Index")" class="btn btn-ghost">Volver</a>
    </div>
</div>

<div class="card" style="padding:2rem;">
    <div class="detail-grid">
        <div class="detail-field full" style="grid-column:1/-1">
            <span class="detail-label">Nombre</span>
            <span class="detail-value large">@Model.Nombre</span>
        </div>

        <div class="detail-field">
            <span class="detail-label">Precio</span>
            <span class="detail-value large">$@Model.Precio.ToString("N2")</span>
        </div>

        <div class="detail-field">
            <span class="detail-label">Stock disponible</span>
            <span class="detail-value large">@Model.Stock unidades</span>
        </div>

        @if (!string.IsNullOrWhiteSpace(Model.Descripcion))
        {
            <div class="detail-field" style="grid-column:1/-1">
                <span class="detail-label">Descripción</span>
                <span class="detail-value" style="color:var(--muted);line-height:1.7;">@Model.Descripcion</span>
            </div>
        }
    </div>

    <div style="margin-top:2rem;padding-top:1.5rem;border-top:1px solid var(--border);display:flex;gap:.5rem;">
        <a href="@Url.Action("Edit",   new { id = Model.Id })" class="btn btn-primary">Editar producto</a>
        <a href="@Url.Action("Delete", new { id = Model.Id })" class="btn btn-danger">Eliminar</a>
        <a href="@Url.Action("Index")" class="btn btn-ghost" style="margin-left:auto;">Ver todos</a>
    </div>
</div>
