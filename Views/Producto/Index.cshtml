@model List<Inventario.Models.ViewModels.IndexViewModel>

@{
    ViewBag.Title = "Productos";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<div class="page-header">
    <div>
        <h1>Productos</h1>
        <p class="subtitle">@Model.Count producto(s) en el sistema</p>
    </div>
    <a href="@Url.Action("Create")" class="btn btn-primary">
        <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><line x1="12" y1="5" x2="12" y2="19" /><line x1="5" y1="12" x2="19" y2="12" /></svg>
        Nuevo producto
    </a>
</div>

@if (!Model.Any())
{
    <div class="card">
        <div class="empty-state">
            <div class="empty-icon">&#128230;</div>
            <p style="font-weight:600;margin-bottom:.4rem;">No hay productos aún</p>
            <p style="font-size:.875rem;margin-bottom:1.25rem;">Comienza agregando tu primer producto al inventario.</p>
            <a href="@Url.Action("Create")" class="btn btn-primary">Agregar producto</a>
        </div>
    </div>
}
else
{
    <div class="table-wrap card">
        <table>
            <thead>
                <tr>
                    <th>#</th>
                    <th>Nombre</th>
                    <th>Precio</th>
                    <th>Stock</th>
                    <th>Estado</th>
                    <th></th>
                </tr>
            </thead>
            <tbody>
                @foreach (var p in Model)
                {
                    <tr>
                        <td style="color:var(--muted);font-size:.8rem;">@p.Id</td>
                        <td style="font-weight:500;">@p.Nombre</td>
                        <td>$@p.Precio.ToString("N2")</td>
                        <td>@p.Stock</td>
                        <td>
                            @if (p.Stock == 0)
                            {
                                <span class="badge badge-zero">Sin stock</span>
                            }
                            else if (p.Stock <= 5)
                            {
                                <span class="badge badge-low">Stock bajo</span>
                            }
                            else
                            {
                                <span class="badge badge-ok">Disponible</span>
                            }
                        </td>
                        <td>
                            <div class="actions">
                                <a href="@Url.Action("Details", new { id = p.Id })" class="btn btn-ghost">Ver</a>
                                <a href="@Url.Action("Edit",    new { id = p.Id })" class="btn btn-secondary">Editar</a>
                                <a href="@Url.Action("Delete",  new { id = p.Id })" class="btn btn-danger">Eliminar</a>
                            </div>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
}
